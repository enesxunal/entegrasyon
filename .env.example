# Supabase PostgreSQL (pooled connection for app queries)
DATABASE_URL=

# Supabase PostgreSQL (direct connection for Prisma migrations)
DIRECT_URL=

# App URL (used by local agent simulator)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session signing (optional in dev; required in production)
AUTH_SECRET=

# Encrypt provider API keys and agent signing keys
# Generate: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=

# Zippr.ink connector mode: mock | real
# Development default: mock (no real API key required)
ZIPPR_MODE=mock

# Optional: real Zippr API key for ZIPPR_MODE=real server-side fallback
ZIPPR_API_KEY=

# One-time Vercel bootstrap seed (POST /api/setup/seed with X-Setup-Secret header)
SEED_SECRET=

# Local agent simulator credentials (from Dashboard → Agents)
AGENT_TEST_ID=
AGENT_TEST_SECRET=
